# ─────────────────────────────────────────────
#  Server
# ─────────────────────────────────────────────
PORT=5000
# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
# Either provide a full connection string...
DATABASE_URL=postgresql://postgres:password@localhost:5432/eden_portfolio
# ...or the individual parts (used only if DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=eden_portfolio
# Set to "true" when connecting to a managed DB that requires SSL (e.g. Render, Supabase)
PGSSL=false

# ─────────────────────────────────────────────
#  Email (Nodemailer via Gmail SMTP)
# ─────────────────────────────────────────────
# The Gmail address that SENDS the notification + where messages are delivered.
MAIL_USER=edenmersha2721@gmail.com
# A Gmail "App Password" (NOT your normal password).
# Create one at: https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
MAIL_PASS=your_16_char_app_password
# Where contact messages should be delivered (defaults to MAIL_USER).
MAIL_TO=edenmersha2721@gmail.com

# ── OPTIONAL: use any SMTP provider instead of Gmail ──
# If Gmail keeps rejecting the login, use a free service like Brevo
# (https://www.brevo.com → SMTP & API → SMTP). Set these and the app
# uses them automatically (they override the Gmail shortcut above):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   MAIL_USER=your_brevo_login
#   MAIL_PASS=your_brevo_smtp_key
# (MAIL_TO stays edenmersha2721@gmail.com so messages still land in your inbox.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
